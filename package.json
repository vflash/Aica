{
  "name": "aica-cli",
  "version": "0.0.3",
  "description": "AI Coding Assistant - HTTP API для управления файлами",
  "main": "bin/aica.js",
  "type": "module",
  "bin": {
    "aica": "./bin/aica.js"
  },
  "scripts": {
    "start": "node bin/aica.js",
    "test": "npm run test:unit",
    "test:unit": "node --test test/parser.test.js test/backup.test.js test/security.test.js test/actions.test.js",
    "test:integration": "node --test test/server.test.js",
    "test:all": "npm run test:unit && npm run test:integration"
  },
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "http",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "diff": "^5.1.0",
    "express": "^4.18.2"
  }
}
